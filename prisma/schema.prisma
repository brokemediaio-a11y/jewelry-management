generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  STAFF
  CLERK
  ACCOUNTANT
  WORKER
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum SaleType {
  PURCHASE
  CUSTOM_ORDER
}

enum SaleStatus {
  COMPLETED
  OPEN
  CANCELLED
}

enum InventoryStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum ItemQuality {
  PREMIUM
  LOCAL
}

enum StoneOptionKind {
  TYPE
  COLOR
  CUT
  CLARITY
}

enum SaleSource {
  INVENTORY
  EXTERNAL
}

enum WorkshopOrderStatus {
  SENT_TO_WORKSHOP
  IN_PROGRESS
  COMPLETE
}

enum ExpenseType {
  BEOPARI
  KAREGAR
  SHOP
  HOME
}

// ============================================
// MODELS
// ============================================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sales    Sale[]
  expenses Expense[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  inventoryItems       InventoryItem[]
  beopariPurchases     BeopariPurchase[]
  beopariPurchaseItems BeopariPurchaseItem[]

  @@map("categories")
}

model StoneOption {
  id        String           @id @default(uuid())
  kind      StoneOptionKind
  name      String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  inventoryAsType    InventoryItem[] @relation("InventoryStoneType")
  inventoryAsColor   InventoryItem[] @relation("InventoryStoneColor")
  inventoryAsCut     InventoryItem[] @relation("InventoryStoneCut")
  inventoryAsClarity InventoryItem[] @relation("InventoryStoneClarity")

  @@unique([kind, name])
  @@index([kind])
  @@map("stone_options")
}

model InventoryItem {
  id                    String          @id @default(uuid())
  sku                   String          @unique
  barcode               String          @unique
  categoryId            String          @map("category_id")
  imageData             String          @map("image_data") @db.Text
  imageMimeType         String          @map("image_mime_type")
  weightGrams           Decimal         @map("weight_grams") @db.Decimal(10, 3)
  itemQuality           ItemQuality     @default(LOCAL) @map("item_quality")
  stoneTypeId           String?         @map("stone_type_id")
  stoneColorId          String?         @map("stone_color_id")
  stoneCutId            String?         @map("stone_cut_id")
  stoneClarityId        String?         @map("stone_clarity_id")
  stonePrice            Decimal?        @map("stone_price") @db.Decimal(10, 2)
  silverRateAtPurchase  Decimal         @map("silver_rate_at_purchase") @db.Decimal(10, 2)
  purchasePricePerGram  Decimal         @map("purchase_price_per_gram") @db.Decimal(10, 2)
  purchasePricePerPiece Decimal         @map("purchase_price_per_piece") @db.Decimal(10, 2)
  status                InventoryStatus @default(AVAILABLE)
  purchasedAt           DateTime        @default(now()) @map("purchased_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  stoneType    StoneOption? @relation("InventoryStoneType", fields: [stoneTypeId], references: [id], onDelete: SetNull)
  stoneColor   StoneOption? @relation("InventoryStoneColor", fields: [stoneColorId], references: [id], onDelete: SetNull)
  stoneCut     StoneOption? @relation("InventoryStoneCut", fields: [stoneCutId], references: [id], onDelete: SetNull)
  stoneClarity StoneOption? @relation("InventoryStoneClarity", fields: [stoneClarityId], references: [id], onDelete: SetNull)
  saleItems    SaleItem[]

  @@index([categoryId])
  @@index([itemQuality])
  @@index([sku])
  @@index([barcode])
  @@index([status])
  @@map("inventory_items")
}

model SilverRateCache {
  id          String   @id @default(uuid())
  currency    String   @default("PKR")
  ratePerGram Decimal  @map("rate_per_gram") @db.Decimal(10, 4)
  source      String   @default("goldpricez")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  rawResponse Json?    @map("raw_response")

  @@index([currency, fetchedAt])
  @@map("silver_rate_cache")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?  @db.Text
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sales Sale[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

model Sale {
  id                 String        @id @default(uuid())
  invoiceNumber      String?       @unique @map("invoice_number")
  saleType           SaleType      @map("sale_type")
  status             SaleStatus    @default(COMPLETED)
  source             SaleSource    @default(INVENTORY)
  customerId         String?       @map("customer_id")
  userId             String        @map("user_id")
  suggestedSalePrice Decimal       @map("suggested_sale_price") @db.Decimal(10, 2)
  finalPrice         Decimal       @map("final_price") @db.Decimal(10, 2)
  silverRateAtSale   Decimal       @map("silver_rate_at_sale") @db.Decimal(10, 2)
  advancePaid        Decimal?      @map("advance_paid") @db.Decimal(10, 2)
  remainingAmount    Decimal?      @map("remaining_amount") @db.Decimal(10, 2)
  pickupDate         DateTime?     @map("pickup_date")
  closedAt           DateTime?     @map("closed_at")
  paymentMethod      PaymentMethod @map("payment_method")
  notes              String?       @db.Text
  sampleImageData     String?      @map("sample_image_data") @db.Text
  sampleImageMimeType String?      @map("sample_image_mime_type")
  orderDescription    String?      @map("order_description") @db.Text
  manualCost          Decimal?     @map("manual_cost") @db.Decimal(10, 2)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         SaleItem[]
  workshopOrder WorkshopOrder?
  expenses      Expense[]

  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
  @@index([invoiceNumber])
  @@index([status])
  @@index([saleType])
  @@index([source])
  @@map("sales")
}

model SaleItem {
  id                    String   @id @default(uuid())
  saleId                String   @map("sale_id")
  inventoryItemId       String?  @map("inventory_item_id")
  categoryName          String?  @map("category_name")
  weightGrams           Decimal  @map("weight_grams") @db.Decimal(10, 3)
  silverRateAtPurchase  Decimal  @map("silver_rate_at_purchase") @db.Decimal(10, 2)
  purchasePricePerPiece Decimal  @map("purchase_price_per_piece") @db.Decimal(10, 2)
  silverRateAtSale      Decimal  @map("silver_rate_at_sale") @db.Decimal(10, 2)
  categoryQuotient      Decimal  @map("category_quotient") @db.Decimal(4, 2)
  suggestedSalePrice    Decimal     @map("suggested_sale_price") @db.Decimal(10, 2)
  finalPrice            Decimal     @map("final_price") @db.Decimal(10, 2)
  itemQuality           ItemQuality @map("item_quality")
  stoneTypeName         String?     @map("stone_type_name")
  stoneColorName        String?     @map("stone_color_name")
  stoneCutName          String?     @map("stone_cut_name")
  stoneClarityName      String?     @map("stone_clarity_name")
  stonePrice            Decimal?    @map("stone_price") @db.Decimal(10, 2)
  createdAt             DateTime    @default(now()) @map("created_at")

  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([inventoryItemId])
  @@map("sale_items")
}

model Karegar {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workshopOrders WorkshopOrder[]
  expenses       Expense[]

  @@map("karegars")
}

model WorkshopOrder {
  id          String              @id @default(uuid())
  saleId      String              @unique @map("sale_id")
  karegarId   String?             @map("karegar_id")
  status      WorkshopOrderStatus @default(SENT_TO_WORKSHOP)
  assignedAt  DateTime?           @map("assigned_at")
  completedAt DateTime?           @map("completed_at")
  notes       String?             @db.Text
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  karegar Karegar? @relation(fields: [karegarId], references: [id], onDelete: SetNull)
  allocations ExpenseWorkshopAllocation[]

  @@index([status])
  @@index([karegarId])
  @@map("workshop_orders")
}

model Expense {
  id            String        @id @default(uuid())
  expenseType   ExpenseType   @map("expense_type")
  amount        Decimal       @db.Decimal(10, 2)
  expenseDate   DateTime      @default(now()) @map("expense_date")
  description   String?       @db.Text
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  userId        String        @map("user_id")

  beopariId String? @map("beopari_id")
  karegarId String? @map("karegar_id")
  saleId    String? @map("sale_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  beopari Beopari? @relation(fields: [beopariId], references: [id], onDelete: SetNull)
  karegar Karegar? @relation(fields: [karegarId], references: [id], onDelete: SetNull)
  sale    Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)

  beopariAllocations  ExpenseBeopariAllocation[]
  workshopAllocations ExpenseWorkshopAllocation[]

  @@index([expenseType])
  @@index([expenseDate])
  @@index([beopariId])
  @@index([karegarId])
  @@map("expenses")
}

model ExpenseBeopariAllocation {
  id                String  @id @default(uuid())
  expenseId         String  @map("expense_id")
  beopariPurchaseId String  @map("beopari_purchase_id")
  amount            Decimal @db.Decimal(10, 2)

  expense         Expense         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  beopariPurchase BeopariPurchase @relation(fields: [beopariPurchaseId], references: [id], onDelete: Cascade)

  @@unique([expenseId, beopariPurchaseId])
  @@index([beopariPurchaseId])
  @@map("expense_beopari_allocations")
}

model ExpenseWorkshopAllocation {
  id              String  @id @default(uuid())
  expenseId       String  @map("expense_id")
  workshopOrderId String  @map("workshop_order_id")
  amount          Decimal @db.Decimal(10, 2)

  expense       Expense       @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  workshopOrder WorkshopOrder @relation(fields: [workshopOrderId], references: [id], onDelete: Cascade)

  @@unique([expenseId, workshopOrderId])
  @@index([workshopOrderId])
  @@map("expense_workshop_allocations")
}

model Beopari {
  id                String   @id @default(uuid())
  name              String
  businessStartDate DateTime @map("business_start_date")
  notes             String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchases BeopariPurchase[]
  expenses  Expense[]

  @@map("beoparis")
}

model BeopariPurchase {
  id           String   @id @default(uuid())
  beopariId    String   @map("beopari_id")
  categoryId   String?  @map("category_id")
  categoryName String   @map("category_name")
  totalWeight  Decimal  @map("total_weight") @db.Decimal(10, 3)
  quantity     Int
  costPerGram  Decimal  @map("cost_per_gram") @db.Decimal(10, 2)
  totalCost    Decimal  @map("total_cost") @db.Decimal(10, 2)
  purchaseDate DateTime @default(now()) @map("purchase_date")
  notes        String?  @db.Text

  beopari     Beopari                    @relation(fields: [beopariId], references: [id], onDelete: Cascade)
  category    Category?                  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items       BeopariPurchaseItem[]
  allocations ExpenseBeopariAllocation[]

  @@index([beopariId])
  @@map("beopari_purchases")
}

model BeopariPurchaseItem {
  id           String  @id @default(uuid())
  purchaseId   String  @map("purchase_id")
  categoryId   String? @map("category_id")
  categoryName String  @map("category_name")
  totalWeight  Decimal @map("total_weight") @db.Decimal(10, 3)
  quantity     Int
  costPerGram  Decimal @map("cost_per_gram") @db.Decimal(10, 2)
  lineTotal    Decimal @map("line_total") @db.Decimal(10, 2)

  purchase BeopariPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@map("beopari_purchase_items")
}

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
